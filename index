<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>메디핏 MediFit | 한의원 전문 브랜드 마케팅</title>
<meta name="description" content="광고 대행이 아니라 한의원 마케팅 구조를 설계합니다. 의료법 안전 · 교육으로 자립 · 비급여 매출 전환. 제약·헬스케어 11년 실무자가 직접.">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css">
<style>
  :root{
    --ink:#17181c;--sub:#5b5e66;--hint:#9498a1;--bg:#f4f5f8;--line:#e9eaef;
    --accent:#7b3ff2;--accent2:#d633e8;--dark1:#1a1430;--dark2:#2a1a52;
    --maxw:1160px;
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  html{scroll-behavior:smooth;}
  h1,h2,h3,h4,.sec-title,.hero h1,.lt-t,.talk h4{word-break:keep-all;}
  body{font-family:"Pretendard Variable",Pretendard,sans-serif;color:var(--ink);background:#fff;line-height:1.7;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
  a{color:inherit;text-decoration:none;}
  img{display:block;max-width:100%;}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 28px;}
  .reveal{opacity:0;transform:translateY(28px);transition:opacity .7s cubic-bezier(.2,.7,.2,1),transform .7s cubic-bezier(.2,.7,.2,1);}
  .reveal.on{opacity:1;transform:none;}
  .d1{transition-delay:.07s}.d2{transition-delay:.14s}.d3{transition-delay:.21s}
  .eyebrow{font-size:12.5px;font-weight:700;color:var(--accent);letter-spacing:1.8px;text-transform:uppercase;margin-bottom:14px;}
  .sec-title{font-size:34px;font-weight:800;line-height:1.32;letter-spacing:-.8px;}
  .sec-lead{font-size:16px;color:var(--sub);margin-top:18px;line-height:1.9;max-width:620px;}
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-weight:700;font-size:15px;padding:15px 26px;border-radius:14px;cursor:pointer;border:0;font-family:inherit;transition:transform .2s,box-shadow .2s;}
  .btn:hover{transform:translateY(-2px);}
  .btn-primary{background:linear-gradient(135deg,#7b3ff2,#d633e8);color:#fff;box-shadow:0 12px 30px rgba(123,63,242,.35);}
  .btn-ghost{background:transparent;border:1px solid rgba(255,255,255,.3);color:#fff;}
  .btn-ghost.dark{border:1px solid var(--line);color:var(--ink);}

  /* NAV */
  header.nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.82);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);}
  .nav-in{max-width:var(--maxw);margin:0 auto;padding:0 28px;height:68px;display:flex;align-items:center;justify-content:space-between;}
  .logo{font-size:21px;font-weight:800;letter-spacing:-.5px;display:flex;flex-direction:column;line-height:1;}
  .logo span{font-size:9.5px;font-weight:600;letter-spacing:1.5px;color:var(--sub);margin-top:3px;}
  .logo b{background:linear-gradient(135deg,#7b3ff2,#d633e8);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
  .nav-links{display:flex;gap:30px;font-size:15px;font-weight:600;color:var(--sub);}
  .nav-links a:hover{color:var(--accent);}
  .nav-cta{padding:11px 20px;font-size:14.5px;border-radius:12px;}

  /* HERO */
  .hero{position:relative;background:#edeef3;overflow:hidden;}
  .hero-blobs{position:absolute;inset:0;z-index:0;}
  .blob{position:absolute;border-radius:50%;filter:blur(3px);}
  .blob1{width:420px;height:420px;background:radial-gradient(circle at 35% 30%,#e85ff0,#c01fd1 55%,#9b0fb0);top:-60px;left:-90px;opacity:.9;}
  .blob2{width:240px;height:240px;background:radial-gradient(circle at 35% 30%,#46e7e7,#13c4c4 60%,#0aa3a3);top:60px;right:8%;opacity:.85;}
  .blob3{width:260px;height:260px;background:radial-gradient(circle at 35% 30%,#9b6bff,#7b3ff2 60%,#5a23c8);bottom:-90px;left:24%;opacity:.85;}
  .hero-veil{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(237,238,243,.55),rgba(237,238,243,.2) 45%,rgba(237,238,243,.7));}
  .hero-in{position:relative;z-index:2;max-width:var(--maxw);margin:0 auto;padding:84px 28px 90px;display:grid;grid-template-columns:1.08fr .92fr;gap:54px;align-items:center;}
  .hero-badge{display:inline-block;background:rgba(123,63,242,.13);color:#5a23c8;font-size:13px;font-weight:700;padding:8px 17px;border-radius:30px;backdrop-filter:blur(4px);}
  .hero h1{font-size:48px;font-weight:800;line-height:1.32;letter-spacing:-1.2px;margin-top:22px;}
  .hero h1 .pt{color:var(--accent);}
  .hero .sub{font-size:17px;color:var(--sub);margin-top:22px;line-height:1.85;font-weight:500;}
  .hero-btns{margin-top:34px;display:flex;gap:13px;flex-wrap:wrap;}
  .hero-chips{margin-top:26px;display:flex;gap:8px;flex-wrap:wrap;}
  .hchip{font-size:12.5px;font-weight:600;color:#5a23c8;background:rgba(255,255,255,.7);border:1px solid rgba(123,63,242,.18);padding:7px 13px;border-radius:30px;}
  .hero-card{background:rgba(255,255,255,.72);backdrop-filter:blur(12px);border-radius:24px;padding:30px;box-shadow:0 24px 60px rgba(20,20,50,.13);border:1px solid rgba(255,255,255,.6);}
  .hero-card .hc-cap{font-size:12.5px;font-weight:700;color:var(--accent);letter-spacing:1px;margin-bottom:18px;}
  .hstat{display:flex;align-items:baseline;gap:12px;padding:16px 0;border-bottom:1px solid var(--line);}
  .hstat:last-child{border-bottom:0;padding-bottom:0;}
  .hstat .v{font-size:34px;font-weight:800;color:var(--accent);letter-spacing:-1px;flex-shrink:0;width:96px;}
  .hstat .l{font-size:13.5px;color:var(--sub);line-height:1.45;}

  /* generic section */
  .sec{padding:104px 0;}
  .sec.tight{padding:88px 0;}
  .dark{background:linear-gradient(155deg,var(--dark1),var(--dark2));color:#fff;}
  .dark .eyebrow{color:#c9b6ff;}
  .center{text-align:center;}
  .center .sec-lead{margin-left:auto;margin-right:auto;}

  /* WHO */
  .who-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:44px;align-items:start;}
  .who-lead{color:#c5bfe0;font-size:16px;line-height:1.95;margin-top:18px;}
  .profile-row{display:flex;align-items:center;gap:22px;margin-top:30px;}
  .profile-photo{width:128px;height:128px;border-radius:50%;overflow:hidden;flex-shrink:0;
    padding:3px;background:linear-gradient(135deg,#7b3ff2,#d633e8);box-shadow:0 14px 36px rgba(123,63,242,.4);}
  .profile-photo img{width:100%;height:100%;border-radius:50%;object-fit:cover;object-position:center top;display:block;border:3px solid #1a1430;}
  .profile-meta{display:flex;flex-direction:column;justify-content:center;}
  .who-name{font-size:26px;font-weight:800;letter-spacing:-.5px;}
  .who-role{font-size:14px;color:#c9b6ff;font-weight:600;margin-top:6px;line-height:1.55;}
  @media (max-width:600px){.profile-photo{width:104px;height:104px;}.who-name{font-size:23px;}}
  .who-quote{margin-top:24px;font-size:16px;line-height:1.95;color:#e8e4f7;font-weight:500;}
  .who-quote b{color:#e879f9;}
  .who-tags{display:flex;flex-wrap:wrap;gap:9px;margin-top:24px;}
  .wtag{font-size:12.5px;font-weight:600;color:#d9ccff;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);padding:8px 15px;border-radius:30px;}
  .lectures{margin-top:24px;display:flex;flex-direction:column;gap:11px;}
  .lecture{display:flex;align-items:center;gap:14px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:12px 14px;}
  .lecture-thumb{flex-shrink:0;width:78px;height:78px;border-radius:13px;overflow:hidden;box-shadow:0 6px 16px rgba(0,0,0,.3);}
  .lecture-thumb img{width:100%;height:100%;object-fit:cover;object-position:center 20%;}
  .lt-t{font-size:14.5px;font-weight:700;color:#fff;}
  .lt-s{font-size:12.5px;color:#c9b6ff;margin-top:3px;}
  .who-media{position:sticky;top:90px;}
  .video-label{font-size:13.5px;color:#c9b6ff;font-weight:600;margin-bottom:13px;}
  .video-frame{position:relative;width:100%;padding-bottom:56.25%;border-radius:20px;overflow:hidden;box-shadow:0 18px 44px rgba(0,0,0,.4);background:#000;}
  .video-frame iframe{position:absolute;inset:0;width:100%;height:100%;border:0;}

  /* THE ORDER */
  .order-flow{display:flex;align-items:stretch;gap:0;margin-top:46px;flex-wrap:wrap;}
  .ostep{flex:1;min-width:150px;background:var(--bg);border-radius:18px;padding:26px 22px;position:relative;}
  .ostep .on{font-size:13px;font-weight:800;color:var(--accent);}
  .ostep h4{font-size:17px;font-weight:800;margin-top:8px;}
  .ostep p{font-size:13.5px;color:var(--sub);margin-top:8px;line-height:1.6;}
  .oarrow{display:flex;align-items:center;color:var(--accent);font-size:22px;font-weight:800;padding:0 10px;}
  .order-note{margin-top:30px;font-size:16px;line-height:1.9;color:var(--ink);}
  .order-note b{color:var(--accent);}

  /* 의료법 */
  .law-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:26px;margin-top:46px;align-items:stretch;}
  .danger{background:linear-gradient(155deg,#291031,#3c1026);border-radius:22px;padding:30px 28px;box-shadow:0 18px 44px rgba(80,10,45,.25);}
  .danger-top{display:inline-flex;align-items:center;gap:9px;font-size:11px;font-weight:800;letter-spacing:1.6px;color:#ffa7bd;background:rgba(255,80,120,.13);padding:7px 14px;border-radius:30px;}
  .danger-dot{width:8px;height:8px;border-radius:50%;background:#ff5d7e;animation:dpulse 1.6s infinite;}
  @keyframes dpulse{0%{box-shadow:0 0 0 0 rgba(255,93,126,.55)}70%{box-shadow:0 0 0 9px rgba(255,93,126,0)}100%{box-shadow:0 0 0 0 rgba(255,93,126,0)}}
  .danger-list{list-style:none;margin-top:18px;}
  .danger-list li{display:flex;gap:15px;align-items:center;padding:17px 0;border-bottom:1px solid rgba(255,255,255,.08);}
  .danger-list li:last-child{border-bottom:0;}
  .danger-list .dn{flex-shrink:0;font-size:16px;font-weight:800;color:#ff8099;width:28px;}
  .danger-list p{font-size:14.5px;color:#ecd9df;line-height:1.55;}
  .danger-list b{color:#fff;}
  .safe{background:#fff;border:1px solid var(--line);border-radius:22px;padding:30px 28px;box-shadow:0 10px 30px rgba(123,63,242,.08);display:flex;flex-direction:column;justify-content:center;}
  .safe-ic{width:44px;height:44px;border-radius:13px;background:linear-gradient(135deg,#7b3ff2,#d633e8);color:#fff;font-weight:800;font-size:22px;display:flex;align-items:center;justify-content:center;margin-bottom:18px;}
  .safe p{font-size:16px;color:var(--ink);line-height:1.9;font-weight:500;}
  .safe b.hl{color:var(--accent);}

  /* 비교표 */
  .cmp{max-width:760px;margin:48px auto 0;display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start;}
  .cmp-col{border-radius:20px;padding:24px 20px;}
  .cmp-them{background:#fff;border:1px solid var(--line);}
  .cmp-us{background:linear-gradient(162deg,#7b3ff2,#a930d4);box-shadow:0 22px 48px rgba(123,63,242,.36);transform:translateY(-12px);}
  .cmp-cap{text-align:center;font-size:15px;font-weight:800;padding-bottom:14px;margin-bottom:6px;}
  .cmp-them .cmp-cap{color:var(--hint);border-bottom:1px solid var(--line);}
  .cmp-us .cmp-cap{color:#fff;border-bottom:1px solid rgba(255,255,255,.22);}
  .cmp-us .cmp-cap span{font-size:10px;font-weight:800;background:#fff;color:var(--accent);padding:3px 8px;border-radius:20px;margin-left:7px;vertical-align:middle;}
  .cmp-item{display:flex;gap:9px;align-items:center;min-height:52px;font-size:13.5px;line-height:1.4;padding:7px 2px;border-bottom:1px dashed var(--line);}
  .cmp-item:last-child{border-bottom:0;}
  .cmp-them .cmp-item{color:var(--hint);}
  .cmp-us .cmp-item{color:#fff;font-weight:600;border-bottom:1px dashed rgba(255,255,255,.2);}
  .cmp-item i{flex-shrink:0;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;font-style:normal;}
  .cmp-them .cmp-item i{background:#f1f1f5;color:#bcbfc8;}
  .cmp-us .cmp-item i{background:rgba(255,255,255,.24);color:#fff;}

  /* HOW */
  .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:46px;}
  .step{background:#fff;border:1px solid var(--line);border-radius:18px;padding:26px 22px;}
  .step-n{width:44px;height:44px;border-radius:13px;background:linear-gradient(135deg,#7b3ff2,#d633e8);color:#fff;font-size:18px;font-weight:800;display:flex;align-items:center;justify-content:center;margin-bottom:18px;}
  .step h4{font-size:17px;font-weight:800;}
  .step h4 .core{font-size:10px;font-weight:800;color:var(--accent);background:#f0e9ff;padding:2px 8px;border-radius:6px;margin-left:6px;vertical-align:middle;}
  .step p{font-size:13.5px;color:var(--sub);margin-top:9px;line-height:1.65;}

  /* 자립 */
  .choice{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:44px;}
  .choice-card{background:#fff;border:1px solid var(--line);border-radius:20px;padding:32px 28px;}
  .choice-card.hi{background:linear-gradient(160deg,var(--dark1),var(--dark2));border:0;}
  .ch-n{font-size:13px;font-weight:800;color:var(--accent);letter-spacing:.5px;}
  .choice-card.hi .ch-n{color:#c9b6ff;}
  .ch-t{font-size:22px;font-weight:800;margin-top:8px;}
  .choice-card.hi .ch-t{color:#fff;}
  .ch-t span{font-size:12px;font-weight:700;color:var(--accent);background:#f0e9ff;padding:3px 9px;border-radius:7px;margin-left:6px;vertical-align:middle;}
  .choice-card.hi .ch-t span{color:#e879f9;background:rgba(232,121,249,.15);}
  .choice-card p{font-size:14.5px;color:var(--sub);line-height:1.8;margin-top:14px;}
  .choice-card.hi p{color:#c5bfe0;}

  /* TRACK */
  .track-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:46px;}
  .track-card{background:#fff;border:1px solid var(--line);border-radius:18px;padding:30px 18px;text-align:center;box-shadow:0 6px 20px rgba(20,20,40,.05);}
  .track-card .v{font-size:32px;font-weight:800;color:var(--accent);letter-spacing:-1px;}
  .track-card .l{font-size:13px;color:var(--sub);margin-top:9px;line-height:1.55;}
  .acc{max-width:760px;margin:26px auto 0;border:1px solid var(--line);border-radius:18px;overflow:hidden;background:#fff;}
  .acc-head{display:flex;justify-content:space-between;align-items:center;padding:20px 24px;font-size:16px;font-weight:700;cursor:pointer;}
  .acc-head .ar{color:var(--accent);transition:transform .35s;font-weight:800;font-size:20px;}
  .acc.open .ar{transform:rotate(45deg);}
  .acc-body{max-height:0;overflow:hidden;transition:max-height .45s ease;background:var(--bg);}
  .acc-inner{padding:10px 24px 24px;display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
  .sys-g .gh{font-size:13px;font-weight:700;color:var(--accent);margin-bottom:10px;}
  .sys-i{font-size:13px;padding:8px 0;border-bottom:1px dashed var(--line);}
  .sys-i:last-child{border-bottom:0;}
  .sys-i span{color:var(--hint);}

  /* FOR 한의원 */
  .targets{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:44px;}
  .target{display:flex;gap:13px;align-items:flex-start;background:linear-gradient(135deg,#f0e9ff,#fbe9fc);border-radius:16px;padding:22px 24px;}
  .target .ch{color:var(--accent);font-weight:800;font-size:18px;}
  .target p{font-size:15px;color:var(--ink);font-weight:500;line-height:1.6;}
  .bg-chips{margin-top:24px;display:flex;flex-wrap:wrap;gap:9px;}
  .bg-chip{font-size:13px;font-weight:700;color:#5a23c8;background:rgba(123,63,242,.1);padding:9px 16px;border-radius:30px;}
  .bg-note{margin-top:18px;font-size:15px;color:var(--sub);line-height:1.7;}

  /* CONTACT */
  .contact{text-align:center;}
  .contact h2{font-size:34px;font-weight:800;letter-spacing:-.8px;line-height:1.35;}
  .contact .csub{font-size:16px;color:#c5bfe0;margin-top:18px;line-height:1.85;}
  .price-note{display:inline-block;margin-top:22px;background:rgba(214,51,232,.18);color:#f0a0fa;font-size:13.5px;font-weight:600;padding:10px 20px;border-radius:30px;}
  .c-btns{margin-top:30px;display:flex;gap:13px;justify-content:center;flex-wrap:wrap;}
  .c-btn{padding:16px 28px;border-radius:14px;font-size:15.5px;font-weight:700;}
  .c-btn.primary{background:linear-gradient(135deg,#7b3ff2,#d633e8);color:#fff;box-shadow:0 12px 30px rgba(123,63,242,.4);}
  .c-btn.kakao{background:#fae100;color:#3c1e1e;}
  .c-btn.ghost{border:1px solid rgba(255,255,255,.25);color:#fff;}

  /* FOOTER */
  .ft-biz{margin-top:34px;padding-top:22px;border-top:1px solid rgba(255,255,255,.08);font-size:12px;color:#7c769c;line-height:2;}
  .ft-bot{margin-top:14px!important;padding-top:0!important;border-top:0!important;}
  footer.ft{background:#120e22;color:#8b85ad;padding:54px 0 40px;}
  .ft-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:32px;}
  .ft-logo{font-size:20px;font-weight:800;color:#fff;}
  .ft-logo span{display:block;font-size:12px;font-weight:500;color:#8b85ad;margin-top:8px;line-height:1.7;}
  .ft h5{font-size:13px;font-weight:700;color:#c9b6ff;margin-bottom:12px;letter-spacing:.5px;}
  .ft a,.ft p{font-size:13.5px;color:#a8a2c4;line-height:2;}
  .ft a:hover{color:#fff;}
  .ft-bot{margin-top:38px;padding-top:22px;border-top:1px solid rgba(255,255,255,.08);font-size:12.5px;color:#6f6991;}

  /* floating CTA (mobile) */
  .float-cta{display:none;}

  /* RESPONSIVE */
  @media (max-width:960px){
    .hero h1{font-size:38px;}
    .hero-in{grid-template-columns:1fr;gap:36px;padding:64px 28px 70px;}
    .who-grid{grid-template-columns:1fr;gap:34px;}
    .who-media{position:static;}
    .law-grid{grid-template-columns:1fr;}
    .steps{grid-template-columns:1fr 1fr;}
    .track-grid{grid-template-columns:1fr 1fr;}
    .acc-inner{grid-template-columns:1fr;}
    .sec-title,.contact h2{font-size:28px;}
    .nav-links{display:none;}
  }
  @media (max-width:600px){
    .wrap{padding:0 20px;}
    .nav-in{padding:0 20px;}
    .sec{padding:72px 0;}
    .hero h1{font-size:31px;letter-spacing:-.8px;}
    .hero .sub{font-size:15.5px;}
    .steps{grid-template-columns:1fr;}
    .track-grid{grid-template-columns:1fr 1fr;}
    .choice{grid-template-columns:1fr;}
    .targets{grid-template-columns:1fr;}
    .order-flow{flex-direction:column;}
    .oarrow{transform:rotate(90deg);padding:6px 0;}
    .hstat .v{font-size:28px;width:80px;}
    .nav-cta{padding:9px 15px;font-size:13.5px;}
    .logo{font-size:18px;}
    .float-cta{display:flex;position:fixed;left:0;bottom:0;width:100%;z-index:90;padding:11px 16px;background:rgba(255,255,255,.92);backdrop-filter:blur(12px);border-top:1px solid var(--line);}
    .float-cta a{flex:1;text-align:center;padding:15px;border-radius:13px;background:linear-gradient(135deg,#7b3ff2,#d633e8);color:#fff;font-weight:700;font-size:15.5px;}
    body{padding-bottom:74px;}
    .cmp-item{min-height:58px;font-size:12.5px;}
  }
  .talks{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:46px;text-align:left;}
  .talk{display:flex;align-items:center;gap:16px;background:#fff;border:1px solid var(--line);border-radius:18px;padding:18px 20px;box-shadow:0 8px 24px rgba(20,20,40,.05);transition:transform .25s,box-shadow .25s;}
  .talk:hover{transform:translateY(-3px);box-shadow:0 14px 34px rgba(20,20,40,.1);}
  .talk-thumb{flex-shrink:0;width:88px;height:88px;border-radius:14px;overflow:hidden;box-shadow:0 6px 16px rgba(20,20,40,.12);}
  .talk-thumb img{width:100%;height:100%;object-fit:cover;object-position:center;}
